<Window x:Class="HttpMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="HTTP Monitor" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- Top: Server + Client side by side -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== SERVER PANEL ===== -->
            <GroupBox Grid.Column="0" Header="HTTP Сервер">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Port + Buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                        <Label Content="Порт:" VerticalAlignment="Center"/>
                        <TextBox x:Name="PortTextBox" Width="70" Text="8080"
                                 VerticalAlignment="Center" Margin="4,0"/>
                        <Button x:Name="StartServerButton" Content="Запустить"
                                Width="90" Margin="4,0" Click="StartServerButton_Click"/>
                        <Button x:Name="StopServerButton" Content="Остановить"
                                Width="90" Margin="4,0" IsEnabled="False" Click="StopServerButton_Click"/>
                        <Button Content="Сохранить логи" Width="100" Margin="4,0"
                                Click="SaveLogsButton_Click"/>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock x:Name="ServerStatusText" Grid.Row="1"
                               Text="Статус: остановлен" Foreground="Red" Margin="0,0,0,4"/>

                    <!-- Stats -->
                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="GET запросы" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="GetCountText" Text="0" FontSize="18"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="POST запросы" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="PostCountText" Text="0" FontSize="18"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Среднее время (мс)" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="AvgTimeText" Text="0" FontSize="18"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="Uptime" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UptimeText" Text="00:00:00" FontSize="18"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Server Log -->
                    <GroupBox Grid.Row="3" Header="Лог сервера">
                        <TextBox x:Name="ServerLogTextBox" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 TextWrapping="NoWrap"
                                 Background="#1E1E1E" Foreground="#D4D4D4"/>
                    </GroupBox>
                </Grid>
            </GroupBox>

            <!-- ===== CLIENT PANEL ===== -->
            <GroupBox Grid.Column="2" Header="HTTP Клиент">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- URL -->
                    <Grid Grid.Row="0" Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="URL:" VerticalAlignment="Center"/>
                        <TextBox x:Name="UrlTextBox" Grid.Column="1"
                                 Text="https://jsonplaceholder.typicode.com/posts"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Method -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                        <Label Content="Метод:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MethodComboBox" Width="80" Margin="4,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="MethodComboBox_SelectionChanged">
                            <ComboBoxItem Content="GET" IsSelected="True"/>
                            <ComboBoxItem Content="POST"/>
                        </ComboBox>
                        <Button Content="Отправить запрос" Width="120" Margin="4,0"
                                Click="SendRequestButton_Click"/>
                        <Button Content="Быстро: POST на сервер" Width="140" Margin="4,0"
                                Click="QuickPostButton_Click"/>
                    </StackPanel>

                    <!-- Request body label -->
                    <Label Grid.Row="2" Content="Тело запроса (JSON):" Margin="0,0,0,2"/>

                    <!-- Request body -->
                    <TextBox x:Name="RequestBodyTextBox" Grid.Row="3"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Text="{}{&quot;message&quot;: &quot;Привет, сервер!&quot;}"
                             IsEnabled="False"/>

                    <!-- Response label -->
                    <Label Grid.Row="4" Content="Ответ:" Margin="0,4,0,2"/>

                    <!-- Response -->
                    <TextBox x:Name="ResponseTextBox" Grid.Row="5"
                             IsReadOnly="True" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="#1E1E1E" Foreground="#D4D4D4"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Separator -->
        <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>

        <!-- Bottom: Logs Table + Chart -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LOGS TABLE ===== -->
            <GroupBox Grid.Column="0" Header="Таблица запросов">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,2">
                        <Label Content="Метод:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FilterMethodCombo" Width="70" Margin="2,0"
                                  SelectionChanged="FilterChanged">
                            <ComboBoxItem Content="Все" IsSelected="True"/>
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                        </ComboBox>
                        <Label Content="Статус:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <ComboBox x:Name="FilterStatusCombo" Width="70" Margin="2,0"
                                  SelectionChanged="FilterChanged">
                            <ComboBoxItem Content="Все" IsSelected="True"/>
                            <ComboBoxItem Content="200"/>
                            <ComboBoxItem Content="400"/>
                            <ComboBoxItem Content="500"/>
                        </ComboBox>
                        <Button Content="Сбросить" Width="70" Margin="8,0" Click="ResetFilter_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="LogsDataGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="65"/>
                            <DataGridTextColumn Header="Метод" Binding="{Binding Method}" Width="50"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                            <DataGridTextColumn Header="Код" Binding="{Binding StatusCode}" Width="45"/>
                            <DataGridTextColumn Header="Время(мс)" Binding="{Binding ProcessingTimeMs}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- ===== CHART ===== -->
            <GroupBox Grid.Column="2" Header="График нагрузки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,2">
                        <Label Content="Разрез:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ChartModeCombo" Width="90" Margin="4,0"
                                  SelectionChanged="ChartModeCombo_SelectionChanged">
                            <ComboBoxItem Content="По минутам" IsSelected="True"/>
                            <ComboBoxItem Content="По часам"/>
                        </ComboBox>
                    </StackPanel>
                    <oxy:PlotView x:Name="RequestsPlotView" Grid.Row="1"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
